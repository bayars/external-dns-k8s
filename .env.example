# Copy to .env and fill in your values before running helmfile.
# Source with: export $(grep -v '^#' .env | xargs)

# Required for both environments
GCP_PROJECT_ID=your-gcp-project-id

# Required for kind environment only
# Absolute path to the GCP service account JSON key downloaded from IAM
GCP_SA_KEY_FILE=/path/to/external-dns-sa-key.json
